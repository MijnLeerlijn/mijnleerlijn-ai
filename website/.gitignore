# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# handleidingen (Sprint 6): opslag is Vercel Blob (payload/upload-manuals-to-blob/,
# lib/knowledge/manuals-blob.ts), niet git — inmiddels 1,6+ GB, hoort niet in
# de repository. Lokaal blijven de bestanden gewoon op schijf staan als bron
# voor het eenmalige uploadscript, alleen niet meer getrackt.
/handleidingen

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
