# Kopieer naar .env en vul in voor lokale ontwikkeling. Zie
# docs/IMPLEMENTATION-PLAN.md Fase 4 en het Fase 4-opleveringsrapport voor
# toelichting per variabele. Nooit echte waarden in dit bestand committen.

# --- Verplicht ---

# Postgres-connectiestring. Zelfde database die later ook pgvector gebruikt
# (zie docs/ARCHITECTURE.md). Geen SQLite, ook niet lokaal.
DATABASE_URI=postgres://user:password@localhost:5432/mijnleerlijn

# Willekeurige, geheime string — gebruikt door Payload om sessies/tokens te
# ondertekenen. Genereer bijv. met `openssl rand -base64 32`.
PAYLOAD_SECRET=

# --- Aanbevolen (heeft een development-fallback, verplicht in productie) ---

# Basis-URL van deze applicatie — gebruikt voor previewlinks en revalidatie.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Vercel Blob (media-uploads + privé contactformulier-bijlagen). Alleen nodig
# wanneer je GEEN Vercel Blob store via OIDC aan dit project hebt gekoppeld
# (Vercel injecteert dan zelf BLOB_STORE_ID/VERCEL_OIDC_TOKEN, geen los token
# nodig — zie services/storage.ts). De Payload-mediaplugin voor de publieke
# `media`-collectie ondersteunt OIDC nog niet en heeft dit token dus altijd
# nodig voor persistente media-uploads op Vercel — zie payload.config.ts.
# Zonder token valt lokale ontwikkeling terug op schijfopslag.
BLOB_READ_WRITE_TOKEN=

# Resend (e-mailnotificatie bij een nieuwe contactinzending). Zonder deze
# variabele wordt de development-e-mailadapter gebruikt (logt naar console,
# verstuurt niets echt). Verplicht in productie.
RESEND_API_KEY=
CONTACT_FROM_EMAIL=noreply@mijnleerlijn.nl
CONTACT_NOTIFICATION_EMAIL=helpdesk@mijnleerlijn.nl

# --- Optioneel ---

# Vercel Cron/andere geplande taken die interne routes aanroepen (bv.
# geplande publicatie, bijlage-opruiming) delen dit geheim ter verificatie.
CRON_SECRET=
